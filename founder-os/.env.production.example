# ===========================================================================
# Founder OS — production env (single-host docker-compose).
# Copy to .env.production and fill in. Bring up with:
#   docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
# Generate secrets with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ===========================================================================

# ---- Postgres (used by the postgres service AND the app DB URLs below) ----
POSTGRES_USER=founder
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=founder_os

# DATABASE_URL host must be the 'postgres' service name; creds must match above.
DATABASE_URL=postgresql+asyncpg://founder:CHANGE_ME_strong_db_password@postgres:5432/founder_os
DATABASE_URL_SYNC=postgresql+psycopg2://founder:CHANGE_ME_strong_db_password@postgres:5432/founder_os

# ---- Redis (the 'redis' service; Celery broker + cache) ----
REDIS_URL=redis://redis:6379/0

# ---- Reverse proxy (Caddy: automatic HTTPS) ----
# Public domains with A records pointing at this server's IP. Caddy fetches
# Let's Encrypt certs for these. Leave defaults for local-only (self-signed).
API_DOMAIN=api.your-domain.com
N8N_DOMAIN=n8n.your-domain.com
ACME_EMAIL=you@your-domain.com

# ---- App ----
APP_ENV=production
DEBUG=false
# JSON array — MUST include your deployed web origin (Vercel domain, custom domain).
CORS_ORIGINS=["https://your-app.vercel.app"]

# ---- Clerk (backend verifies JWTs; use your PRODUCTION instance) ----
CLERK_ISSUER=https://YOUR-INSTANCE.clerk.accounts.dev
CLERK_JWKS_URL=https://YOUR-INSTANCE.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=

# ---- LLM (cheap path: a HOSTED api, not self-hosted Ollama) ----
# Option A — Groq (OpenAI-compatible, free tier). Recommended.
LLM_PROVIDER=openai_compatible
OPENAI_API_KEY=gsk_YOUR_GROQ_KEY
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
# Option B — Gemini:    LLM_PROVIDER=gemini      + GEMINI_API_KEY=...
# Option C — Anthropic: LLM_PROVIDER=anthropic   + ANTHROPIC_API_KEY=...

# ---- Embeddings ----
# Groq has no embeddings endpoint. Cheapest hosted option = OpenAI text-embedding-3-small
# (1536 dims, matches the pgvector column). Alternatively run a tiny Ollama just for
# embeddings (EMBEDDING_PROVIDER=ollama + an ollama container) to stay fully free.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=sk_YOUR_OPENAI_KEY
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1536

# ---- Workflow callback signing (REQUIRED — app refuses to boot if APP_ENV!=development) ----
# Public base URL the *outside world / n8n* uses to reach this API.
WORKFLOW_CALLBACK_BASE_URL=https://api.your-domain.com
WORKFLOW_CALLBACK_SECRET=CHANGE_ME_run_token_urlsafe_32

# ---- n8n (only needed if you run `--profile n8n`) ----
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=
N8N_HOST=your-domain.com
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://n8n.your-domain.com
WEBHOOK_URL=https://n8n.your-domain.com/
GENERIC_TIMEZONE=Asia/Kolkata

# ---- Optional integrations ----
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://api.your-domain.com/api/planner/connect/callback
# SERPAPI_KEY=
# TAVILY_API_KEY=
