# ── Clerk Auth ────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# Clerk redirect URLs (adjust if running on a different port)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── API Backend ────────────────────────────────────────
# URL of the FastAPI backend — used by Next.js rewrites and direct fetch calls.
# Leave as localhost:8000 for local development.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Stripe (for client-side redirect) ─────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
