# ─────────────────────────────────────────────────
# Founder OS — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://founder:founder@localhost:5432/founder_os
DATABASE_URL_SYNC=postgresql+psycopg2://founder:founder@localhost:5432/founder_os

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Clerk Auth ────────────────────────────────────────
CLERK_ISSUER=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev
CLERK_JWKS_URL=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=

# ── LLM Provider ──────────────────────────────────────
# Options: "ollama" | "anthropic" | "openai_compatible" | "gemini"
LLM_PROVIDER=ollama

# Ollama (free, local — default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI-compatible / Groq (if LLM_PROVIDER=openai_compatible)
# Get Groq key from https://console.groq.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Gemini (if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Embedding Provider ────────────────────────────────
# Options: "ollama" | "openai"
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1536

# ── App ───────────────────────────────────────────────
APP_ENV=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Google Calendar (optional) ────────────────────────
# Create OAuth2 credentials at https://console.cloud.google.com
# ── LLM Provider ──────────────────────────────────────
# Choose one: "ollama" | "anthropic" | "openai_compatible" | "gemini"
# Default is "ollama" (free, runs locally — install from https://ollama.com)
LLM_PROVIDER=ollama

# Ollama (free, local — default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic Claude (optional — https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI-compatible (OpenAI, Groq, Together AI, LM Studio, vLLM, etc.)
# For Groq: set OPENAI_BASE_URL=https://api.groq.com/openai/v1 and OPENAI_MODEL=llama-3.3-70b-versatile
# For OpenAI: leave OPENAI_BASE_URL as default and set OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Gemini (Google AI Studio — https://aistudio.google.com)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Embeddings ────────────────────────────────────────
# Choose one: "ollama" | "openai" | "openai_compatible"
# Ollama uses nomic-embed-text (free, local). OpenAI uses text-embedding-3-small.
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1536

# ── Google Calendar Integration (optional) ────────────
# Create a project at https://console.cloud.google.com with Calendar API enabled.
# Set OAuth redirect URI to: http://127.0.0.1:8000/api/planner/connect/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/planner/connect/callback

# ── Web Search (optional) ─────────────────────────────
# For real web_search tool — pick one:
# SerpAPI: https://serpapi.com (100 free searches/month)
SERPAPI_KEY=
# Tavily: https://tavily.com (1000 free searches/month)
TAVILY_API_KEY=
# ── MCP Tool Servers (optional) ───────────────────────
# JSON array of external MCP server configs. In-process providers (Google Calendar)
# are auto-registered and do not need entries here.
# Example: [{"name":"github","transport":"stdio","command":"npx","args":["@modelcontextprotocol/server-github"]}]
MCP_SERVERS=[]
