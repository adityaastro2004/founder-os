# ─────────────────────────────────────────────────
# Founder OS — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://founder:founder@localhost:5432/founder_os
DATABASE_URL_SYNC=postgresql+psycopg2://founder:founder@localhost:5432/founder_os

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Clerk Auth ────────────────────────────────────────
CLERK_ISSUER=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev
CLERK_JWKS_URL=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=

# ── LLM Provider ──────────────────────────────────────
# Options: "ollama" | "anthropic" | "openai_compatible" | "gemini"
LLM_PROVIDER=ollama

# Ollama (free, local — default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI-compatible / Groq (if LLM_PROVIDER=openai_compatible)
# Get Groq key from https://console.groq.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Gemini (if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Embedding Provider ────────────────────────────────
# Options: "ollama" | "openai"
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1536

# ── App ───────────────────────────────────────────────
APP_ENV=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Workflow callbacks (Track B — ADR-008) ────────────
# Base URL n8n HTTP nodes call back into Founder OS with (must be reachable from n8n).
WORKFLOW_CALLBACK_BASE_URL=http://localhost:8000
# HMAC signing secret for per-workflow callback tokens (O-2). NEVER commit a real value.
# Required (≥32 bytes of entropy) whenever APP_ENV != development — the app fails to
# start otherwise. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
WORKFLOW_CALLBACK_SECRET=
# Optional rollover slot for zero-downtime secret rotation via key-id (kid).
WORKFLOW_CALLBACK_SECRET_PREVIOUS=

# ── Google Calendar (optional) ────────────────────────
# Create OAuth2 credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/planner/connect/callback
OAUTH_STATE_SECRET=

# ── Web Search (optional) ─────────────────────────────
# For real web_search tool — pick one:
# SerpAPI: https://serpapi.com (100 free searches/month)
SERPAPI_KEY=
# Tavily: https://tavily.com (1000 free searches/month)
TAVILY_API_KEY=

# ── Stripe Payments (test mode) ───────────────────────
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
# Create webhook at https://dashboard.stripe.com/test/webhooks
# → endpoint URL: https://YOUR_DOMAIN/api/billing/webhook
# → events: checkout.session.completed, customer.subscription.updated,
#            customer.subscription.deleted, invoice.payment_succeeded,
#            invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
# Create Products + Prices in Stripe Dashboard, paste their price_xxx IDs:
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ── n8n (Track A) — workflow execution backend ─────────
# Self-hosted OSS n8n (see founder-os/docker-compose.yml, "n8n" profile; ADR-008).
# Started by default via ./start.sh; opt out with: FOS_DISABLE_N8N=1 ./start.sh
#
# Base URL of the n8n REST API + editor. The Founder OS API calls this to
# push/trigger workflows and builds the editor link-out:
#   {N8N_BASE_URL}/workflow/{n8n_workflow_id}
N8N_BASE_URL=http://localhost:5678
# n8n REST API key — create in the n8n editor: Settings -> n8n API -> Create API Key.
# Secret: never commit a real value, never log it.
N8N_API_KEY=

# ── Company State Engine (slice 1: Obsidian) ────────────────────────────
# Vault paths are per-user runtime config (POST /api/state/sources), not env.
# Docker note: the API reads the vault path AS SEEN BY THE PROCESS. Under
# docker-compose, mount your vault (e.g. `- /Users/me/Vault:/vaults/main:rw`)
# and register /vaults/main. ./start.sh (host uvicorn) uses host paths directly.
# Tunables (defaults in app/config.py): STATE_DEDUP_SIM_THRESHOLD=0.88,
# STATE_WRITE_GATE_JUDGE_MAX_PER_SYNC=10, STATE_WRITE_GATE_JUDGE_TIMEOUT_S=30,
# STATE_OBSIDIAN_MAX_FILES=5000, STATE_OBSIDIAN_MAX_FILE_BYTES=1048576
