"""
Founder OS — User Context & Token Store
==========================================
Persistent in-memory store for user onboarding data, business context,
and Google Calendar tokens.

In production, replace with PostgreSQL (the schema already has users/
integrations tables). For now this provides a clean abstraction layer.
"""

from __future__ import annotations

import time
import uuid
import logging
from datetime import datetime, timezone
from typing import Any

from pydantic import BaseModel, Field

logger = logging.getLogger(__name__)


# ============================================================================
# Models
# ============================================================================

class UserProfile(BaseModel):
    """Everything we know about a founder — set once during onboarding
       or updated any time via natural-language message."""
    user_id: str = Field(default_factory=lambda: f"user-{uuid.uuid4().hex[:8]}")
    name: str = ""

    # Business basics
    business_name: str = ""
    business_type: str = ""          # B2B SaaS, D2C, marketplace, agency, etc.
    business_stage: str = ""         # idea, mvp, seed, series-a, profitable
    industry: str = ""
    target_audience: str = ""
    team_size: int = 1

    # Metrics
    current_mrr: float = 0.0
    current_users: int = 0
    mrr_growth_pct: float = 0.0

    # Weekly planning inputs
    primary_goal: str = ""
    goals_this_week: list[str] = Field(default_factory=list)
    completed_last_week: list[str] = Field(default_factory=list)
    blockers: list[str] = Field(default_factory=list)
    custom_instructions: str = ""    # e.g. "I like 2h deep work blocks"

    # Preferences
    timezone: str = "Asia/Kolkata"
    preferred_work_hours: str = "09:00-18:00"
    calendar_id: str = "primary"

    # Google Calendar
    gcal_connected: bool = False
    gcal_tokens: dict[str, Any] = Field(default_factory=dict)

    # Metadata
    created_at: str = Field(
        default_factory=lambda: datetime.now(timezone.utc).isoformat()
    )
    last_plan_at: str | None = None
    last_plan_events: int = 0
    plan_count: int = 0

    def store_gcal_tokens(self, tokens: dict[str, Any]) -> None:
        tokens["stored_at"] = time.time()
        self.gcal_tokens = tokens
        self.gcal_connected = True

    def has_valid_gcal_tokens(self) -> bool:
        if not self.gcal_tokens:
            return False
        stored_at = self.gcal_tokens.get("stored_at", 0)
        expires_in = self.gcal_tokens.get("expires_in", 3600)
        refresh_token = self.gcal_tokens.get("refresh_token")
        # Valid if not expired, OR if we have a refresh token
        if time.time() < stored_at + expires_in - 60:
            return True
        return bool(refresh_token)


# ============================================================================
# In-memory store  (keyed by user_id)
# ============================================================================

_users: dict[str, UserProfile] = {}


def get_user(user_id: str) -> UserProfile | None:
    return _users.get(user_id)


def get_or_create_user(user_id: str) -> UserProfile:
    if user_id not in _users:
        _users[user_id] = UserProfile(user_id=user_id)
        logger.info("Created new user profile: %s", user_id)
    return _users[user_id]


def save_user(user: UserProfile) -> None:
    _users[user.user_id] = user


def list_users() -> list[UserProfile]:
    return list(_users.values())


def get_users_with_gcal() -> list[UserProfile]:
    """Return all users who have connected Google Calendar."""
    return [u for u in _users.values() if u.gcal_connected and u.has_valid_gcal_tokens()]


def delete_user(user_id: str) -> bool:
    return _users.pop(user_id, None) is not None


def update_user_context(user_id: str, updates: dict[str, Any]) -> UserProfile:
    """Merge partial updates into a user profile."""
    user = get_or_create_user(user_id)
    for key, value in updates.items():
        if value is not None and hasattr(user, key):
            setattr(user, key, value)
    save_user(user)
    return user
